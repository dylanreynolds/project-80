# ============================================================
#  IT Automation — Environment Variables
#  Copy to .env (or deploy via Azure App Configuration / Intune)
# ============================================================

# ---- Shared secret (all three services must share this) ----
ORCHESTRATOR_API_KEY=your-strong-random-secret-here

# ---- Teams Bot (teams-bot/) --------------------------------
MicrosoftAppId=           # Azure Bot registration App ID
MicrosoftAppPassword=     # Azure Bot registration App Password / client secret
PORT=3978

SERVICENOW_INSTANCE=mycompany          # just the subdomain, not the full URL
SERVICENOW_USERNAME=svc_bot_integration
SERVICENOW_PASSWORD=

ORCHESTRATOR_URL=https://orchestrator.internal.company.com
ORCHESTRATOR_API_KEY=                  # same value as above

# ---- Orchestrator (orchestrator/) --------------------------
# KB Advisory — Bing Web Search API
# Create at: portal.azure.com → Bing Search v7 resource
BING_API_KEY=

# KB Advisory — Azure OpenAI
# Create at: portal.azure.com → Azure OpenAI resource → deploy gpt-4o model
AZURE_OPENAI_ENDPOINT=https://mycompany.openai.azure.com
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
SERVICENOW_INSTANCE=mycompany
SERVICENOW_USERNAME=svc_bot_integration
SERVICENOW_PASSWORD=

AZURE_TENANT_ID=           # Your M365 tenant GUID
AZURE_CLIENT_ID=           # App registration for Graph API licence assignment
AZURE_CLIENT_SECRET=

SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;...

TEAMS_BOT_URL=https://bot.internal.company.com
DEVICE_REGISTRY_URL=http://localhost:8000   # same service, /devices endpoint
PORT=8000

# ---- Local Desktop Agent (local-agent/) --------------------
AGENT_SERVICE_BUS_CONN=Endpoint=sb://your-namespace.servicebus.windows.net/;...
ORCHESTRATOR_URL=https://orchestrator.internal.company.com
ORCHESTRATOR_API_KEY=                  # same value as above
AGENT_USER_EMAIL=                      # populated at Intune enrolment time

# SCCM (optional — leave blank to use winget only)
SCCM_SERVER=sccm.internal.company.com
SCCM_SITE=PS1
SCCM_API_KEY=
